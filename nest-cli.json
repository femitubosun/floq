{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": ["infrastructure/prisma/generated/**/*", "infrastructure/prisma/scripts/**/*",
      "infrastructure/mail/templates/**/*"],
    "watchAssets": true
  }

}
